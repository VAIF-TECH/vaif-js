{
  "name": "@vaif/client",
  "version": "0.2.0",
  "description": "The official TypeScript library for the Vaif API",
  "author": "Vaif <support@vaif.tech>",
  "types": "dist/index.d.ts",
  "main": "dist/index.js",
  "type": "commonjs",
  "repository": "github:VAIF-TECH/vaif-js",
  "license": "Apache-2.0",
  "packageManager": "yarn@1.22.22",
  "files": [
    "**/*"
  ],
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "test": "./scripts/test",
    "build": "./scripts/build",
    "prepublishOnly": "echo 'to publish, run yarn build && (cd dist; yarn publish)' && exit 1",
    "format": "./scripts/format",
    "prepare": "if ./scripts/utils/check-is-in-git-install.sh; then ./scripts/build && ./scripts/utils/git-swap.sh; fi",
    "tsn": "ts-node -r tsconfig-paths/register",
    "lint": "./scripts/lint",
    "fix": "./scripts/format"
  },
  "dependencies": {
    "eventsource": "^4.1.0",
    "p-limit": "^7.3.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.17.0",
    "@swc/core": "^1.3.102",
    "@swc/jest": "^0.2.29",
    "@types/eventsource": "^3.0.0",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.4.0",
    "@types/node": "^20.17.6",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "8.31.1",
    "@typescript-eslint/parser": "8.31.1",
    "eslint": "^9.39.1",
    "eslint-plugin-unused-imports": "^4.1.4",
    "express": "^5.2.1",
    "iconv-lite": "^0.6.3",
    "jest": "^29.4.0",
    "prettier": "^3.0.0",
    "publint": "^0.2.12",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.5.0",
    "tsc-multi": "https://github.com/stainless-api/tsc-multi/releases/download/v1.1.9/tsc-multi.tgz",
    "tsconfig-paths": "^4.0.0",
    "tslib": "^2.8.1",
    "typescript": "5.8.3",
    "typescript-eslint": "8.31.1",
    "vitest": "^4.1.5",
    "ws": "^8.20.0"
  },
  "peerDependencies": {
    "ws": "*"
  },
  "peerDependenciesMeta": {
    "ws": {
      "optional": true
    }
  },
  "overrides": {
    "minimatch": "^9.0.5"
  },
  "pnpm": {
    "overrides": {
      "minimatch": "^9.0.5"
    }
  },
  "resolutions": {
    "minimatch": "^9.0.5"
  },
  "sideEffects": false,
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./realtime": {
      "import": "./dist/lib/realtime/index.mjs",
      "require": "./dist/lib/realtime/index.js",
      "types": "./dist/lib/realtime/index.d.ts"
    },
    "./storage": {
      "import": "./dist/lib/storage/index.mjs",
      "require": "./dist/lib/storage/index.js",
      "types": "./dist/lib/storage/index.d.ts"
    },
    "./storage/browser": {
      "import": "./dist/lib/storage/browser.mjs",
      "require": "./dist/lib/storage/browser.js",
      "types": "./dist/lib/storage/browser.d.ts"
    },
    "./storage/resume": {
      "import": "./dist/lib/storage/resume.mjs",
      "require": "./dist/lib/storage/resume.js",
      "types": "./dist/lib/storage/resume.d.ts"
    },
    "./*.mjs": {
      "default": "./dist/*.mjs"
    },
    "./*.js": {
      "default": "./dist/*.js"
    },
    "./*": {
      "import": "./dist/*.mjs",
      "require": "./dist/*.js"
    }
  }
}
